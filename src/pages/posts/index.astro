---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NetworkBg from "../../components/NetworkBg.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Posts" description="Thoughts, tutorials, and insights on technology, AI, math, and education">
  <section class="relative overflow-hidden">
    <NetworkBg id="posts-bg" nodeCount={50} />
    <div class="relative z-10 text-white py-16 text-center">
      <div class="max-w-5xl mx-auto px-4">
        <h1 class="text-4xl font-bold mb-2">Blog Posts</h1>
        <p class="text-lg opacity-90">Thoughts, tutorials, and insights on technology, AI, math, and education</p>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <article class="bg-white rounded-xl shadow-md overflow-hidden hover:-translate-y-1 hover:shadow-lg transition-all duration-300" style="border:2px solid #5B8731;border-top:5px solid #5B8731;">
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <time class="text-sm text-gray-500">April 14, 2026</time>
            <span class="text-sm text-gray-400">&middot; 15 min</span>
          </div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">
            <a href="/posts/minecraft-learning" class="hover:text-green-600 transition-colors">
              Minecraft and the People Who Play It
            </a>
          </h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">How a game written in one week became the best-selling video game ever&nbsp;&mdash; and why lion cubs, bear cubs, and your child at the computer have more in common than you think.</p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded-md font-medium">Minecraft</span>
            <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Education</span>
            <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Programming</span>
            <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Game Design</span>
          </div>
          <a
            href="/posts/minecraft-learning"
            class="text-green-600 font-semibold text-sm hover:text-green-800 transition-colors"
          >
            Read More &rarr;
          </a>
        </div>
      </article>
      {
        posts.map((post, index) => (
          <Fragment>
          {index === 0 && (
            <article class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <time class="text-sm text-gray-500">March 22, 2026</time>
                  <span class="text-sm text-gray-400">· 5 min</span>
                </div>
                <h2 class="text-xl font-semibold text-gray-900 mb-2">
                  <a href="/nice-cyprus/" class="hover:text-purple-600 transition-colors">
                    Nice Cyprus: The Bright and Dark Sides of Island Life
                  </a>
                </h2>
                <p class="text-gray-600 text-sm leading-relaxed mb-4">12 interactive flip cards about living in Cyprus from weather and driving to schools and sunsets. Available in English, Russian, and Greek.</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Cyprus</span>
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Interactive</span>
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Expat Life</span>
                </div>
                <a
                  href="/nice-cyprus/"
                  class="text-purple-600 font-semibold text-sm hover:text-purple-800 transition-colors"
                >
                  Explore →
                </a>
              </div>
            </article>
          )}
          {index === 1 && (
            <article class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <time class="text-sm text-gray-500">February 26, 2026</time>
                  <span class="text-sm text-gray-400">· 20 min</span>
                </div>
                <h2 class="text-xl font-semibold text-gray-900 mb-2">
                  <a href="/data-viz-quiz/" class="hover:text-purple-600 transition-colors">
                    Can You Read Data? Test Your Visualization Skills
                  </a>
                </h2>
                <p class="text-gray-600 text-sm leading-relaxed mb-4">30 charts, maps, and graphs — guess what story each one tells. Two games, six legendary heroes to unlock, from Florence Nightingale to Gauss.</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Data Visualization</span>
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Interactive Quiz</span>
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">Statistics</span>
                </div>
                <a
                  href="/data-viz-quiz/"
                  class="text-purple-600 font-semibold text-sm hover:text-purple-800 transition-colors"
                >
                  Take Quiz →
                </a>
              </div>
            </article>
          )}
          {post.id !== 'minecraft-learning' && (
          <article class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <time class="text-sm text-gray-500" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                {post.data.readingTime && (
                  <span class="text-sm text-gray-400">· {post.data.readingTime}</span>
                )}
              </div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                <a href={`/posts/${post.id}`} class="hover:text-purple-600 transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{post.data.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.map((tag: string) => (
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-md font-medium">
                    {tag}
                  </span>
                ))}
              </div>
              <a
                href={`/posts/${post.id}`}
                class="text-purple-600 font-semibold text-sm hover:text-purple-800 transition-colors"
              >
                Read More →
              </a>
            </div>
          </article>
          )}
          </Fragment>
        ))
      }
    </div>

    <div class="text-center mt-12 p-6 bg-gray-50 rounded-xl">
      <p class="text-gray-600">
        Join <a href="https://t.me/TechneNotes" class="text-purple-600 hover:underline font-medium">Telegram channel</a> and share your thoughts!
      </p>
    </div>
  </div>
</BaseLayout>
